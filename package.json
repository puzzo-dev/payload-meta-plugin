{
  "name": "payload-meta-plugin",
  "version": "0.1.0",
  "description": "Payload CMS plugin for connecting multi-tenant sites to Meta's network (Facebook Pixel + Conversions API, Facebook/Instagram Commerce Catalog, WhatsApp Business Cloud API). Modular per-channel, per-site — nothing hardcoded to one product line.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./components/MetaConnectPanel": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/components/MetaConnectPanel/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/components/MetaConnectPanel/index.js"
      }
    },
    "./components/MetaPixelSelect": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/components/MetaPixelSelect/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/components/MetaPixelSelect/index.js"
      }
    },
    "./components/ThreadsConnectPanel": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/components/ThreadsConnectPanel/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/components/ThreadsConnectPanel/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/components/MetaConnectPanel/index.tsx src/components/MetaPixelSelect/index.tsx src/components/ThreadsConnectPanel/index.tsx --format cjs,esm --dts --clean --out-dir dist",
    "dev": "tsup src/index.ts src/components/MetaConnectPanel/index.tsx src/components/MetaPixelSelect/index.tsx src/components/ThreadsConnectPanel/index.tsx --format cjs,esm --dts --watch --out-dir dist",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test 'src/**/*.test.ts'",
    "lint": "eslint src",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "payload",
    "payloadcms",
    "meta",
    "facebook",
    "instagram",
    "whatsapp",
    "cms",
    "plugin"
  ],
  "author": "puzzo-dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/puzzo-dev/payload-meta-plugin.git"
  },
  "homepage": "https://github.com/puzzo-dev/payload-meta-plugin#readme",
  "bugs": {
    "url": "https://github.com/puzzo-dev/payload-meta-plugin/issues"
  },
  "peerDependencies": {
    "@payloadcms/ui": "3.84.1",
    "payload": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "next": "16.2.6",
    "payload": "^3.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
